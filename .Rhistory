options <- tibble(single = c("Yes", "No"))
sim_proportions_billie <- options %>%
rep_sample_n(size = 1000, reps = 5000,
replace = TRUE, prob = c(.29, .71)) %>%
count(single) %>%
mutate(p_hat = n /sum(n)) %>%
filter(fan == "Yes")
billie_plot <- ggplot(data = sim_proportions_billie, aes(x = p_hat)) +
geom_histogram( color = "white", binwidth = 310/1000) +
labs(
x = "Simulated p_hat",
title = "Parametric Bootstrap Distribution of p_hat",
subtitle = "Sample size (n) = 178, Number of Null Statistics (B) = 1000, p = 0.5"
)+
theme(plot.title=element_text(size=10),
axis.title=element_text(size=6),
axis.text=element_text(size=6),
plot.subtitle=element_text(size=6))+
geom_vline(xintercept= 310/1000, color = "red")
billie_plot
